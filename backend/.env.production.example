NODE_ENV=production
PORT=5000

# Must point to staging first, then production after verification.
DATABASE_URL="mysql://user:password@db-host:3306/database_name"

# Exact frontend origin. Do not use * with cookie auth.
FRONTEND_ORIGIN=https://www.example.com

JWT_SECRET=replace-with-a-long-random-production-secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=admin_session
COOKIE_SECURE=true

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ethio Origins Tours <contact@example.com>"
ADMIN_EMAIL=
EMAIL_ENABLED=true

# SendGrid (takes priority over SMTP when configured)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# In production this can remain "." to use backend/assets, or point at a mounted media root.
UPLOAD_ROOT=.
PUBLIC_FILE_BASE_URL=https://www.example.com
MAX_UPLOAD_MB=5

# Redis (required for BullMQ email queue)
REDIS_URL=redis://localhost:6379

# Sentry (error tracking + performance monitoring)
SENTRY_DSN=
