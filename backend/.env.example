NODE_ENV=development
PORT=5000

# Use a staging database or local imported dump, not production.
DATABASE_URL="mysql://user:password@127.0.0.1:3306/database_name"

FRONTEND_ORIGIN=http://localhost:3000

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=admin_session
COOKIE_SECURE=false

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ethio Origins Tours <contact@example.com>"
ADMIN_EMAIL=
EMAIL_ENABLED=false

# SendGrid (takes priority over SMTP when configured)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Path root for storing uploaded image files.
UPLOAD_ROOT=.
PUBLIC_FILE_BASE_URL=
MAX_UPLOAD_MB=5

# Redis (required for BullMQ email queue)
REDIS_URL=redis://localhost:6379

# Sentry (error tracking + performance monitoring)
SENTRY_DSN=

# AI Assistant (Chat)
ASSISTANT_PROVIDER=gemini         # gemini | openai | anthropic | grok
ASSISTANT_MODEL=gemini-2.0-flash  # Model for the chosen provider
# Only the API key for your chosen provider is required.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
